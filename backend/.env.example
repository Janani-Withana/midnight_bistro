PORT=3001
NODE_ENV=development
JWT_SECRET=midnight-bistro-jwt-secret
ADMIN_SECRET=midnight-bistro-admin-secret

# Default: local Postgres. For Render, replace with External Database URL from the Render Postgres dashboard.
DATABASE_URL=postgresql://localhost:5432/midnight_bistro

# Render example (use the exact URL Render shows; host usually ends with .REGION.postgres.render.com:5432):
# DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxxxx-a.REGION.postgres.render.com:5432/DBNAME?sslmode=require

# Optional: force SSL (usually auto when URL contains render.com / sslmode=require / neon / supabase)
# DATABASE_SSL=true
